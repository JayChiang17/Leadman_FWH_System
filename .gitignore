# Ignore everything except tracked project files
/*
!/frontend/
!/backend/
!/registry/
!/CLAUDE.md
!/.gitignore
!/docker-compose.yml
!/docker-compose.dev.yml
!/docker-compose.registry.yml
!/Makefile
!/.github/

# Registry auth — generated by registry/setup.sh, never commit credentials
registry/auth/htpasswd

# Database files at root level
*.db
*.db-shm
*.db-wal

# Database files in backend/data/
backend/data/*.db
backend/data/*.db-shm
backend/data/*.db-wal

# Lock files and OS artefacts
backend/data/*.lock
frontend/nul

# Secrets — never commit these
backend/.env
.env

# Local caches and package installs
backend/.cache/
backend/.local/
