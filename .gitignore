# Ignore everything except tracked project files
/*
!/frontend/
!/backend/
!/CLAUDE.md
!/.gitignore
!/docker-compose.yml
!/docker-compose.dev.yml
!/Makefile
!/.github/

# Database files at root level
*.db
*.db-shm
*.db-wal

# Database files in backend/data/
backend/data/*.db
backend/data/*.db-shm
backend/data/*.db-wal

# Lock files and OS artefacts
backend/data/*.lock
frontend/nul

# Local caches and package installs
backend/.cache/
backend/.local/
