# Ignore everything except frontend and backend
/*
!/frontend/
!/backend/
!/CLAUDE.md
!/.gitignore

# Database files at root level
*.db
*.db-shm
*.db-wal

# Database files in backend/data/
backend/data/*.db
backend/data/*.db-shm
backend/data/*.db-wal

# Lock files and OS artefacts
backend/data/*.lock
frontend/nul
