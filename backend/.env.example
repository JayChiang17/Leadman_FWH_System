# ============================================================
# Leadman Production System - Environment Configuration
# ============================================================

# ===== FastAPI / Auth =====
SECRET_KEY=your-secret-key-here-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== Database (PostgreSQL) =====
DATABASE_URL=postgresql://leadman:leadman_dev_pw@localhost:5432/leadman

# ===== Microsoft Graph API 郵件設定 =====
# Azure AD 憑證 (請填入你自己的 Azure AD 應用程式憑證)
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret

# 發件人設定（必須是你組織中的真實郵箱）
SENDER_EMAIL=your-email@example.com
EMAIL_FROM_NAME=Leadman Production System

# ===== 每日報告設定 =====
# 發送時間（24小時制，格式 HH:MM）
REPORT_SEND_TIME=18:00

# 收件人列表（多個郵箱用逗號分隔）
# 報告包含：生產數據、NG統計、Downtime總結
DAILY_REPORT_EMAILS=recipient@example.com

# ===== WebSocket Redis Bus (optional for multi-instance) =====
# Leave WS_REDIS_URL empty to run in local-only mode.
WS_REDIS_URL=
WS_REDIS_CHANNEL=leadman:ws:broadcast
# Optional base id. Runtime will append process id automatically.
WS_INSTANCE_ID=
WS_REDIS_RETRY_SECONDS=5
